duct description, call-to-action button, feature highlights grid, and footer with social links. Ensure it works across all email clients."},{icon:eO.Image,label:"Photo Gallery",prompt:"Build a responsive photo gallery with a masonry grid layout. Include lightbox functionality for viewing full-size images, smooth transitions, keyboard navigation, thumbnails, and lazy loading for performance. Add filtering by categories."},{icon:rO.Kv,label:"Quiz App",prompt:"Create an interactive quiz application with multiple choice questions. Include a progress bar, timer, score tracking, instant feedback for answers, and a results page showing correct/incorrect answers. Add the ability to restart the quiz."},{icon:rV.ChartActivity,label:"Tip Calculator",prompt:"Design a tip calculator that splits bills among multiple people. Include inputs for bill amount, tip percentage with preset options, number of people, and display the total per person. Show tip amount and total bill with smooth animations."}],[{icon:rD.Envelope,label:"Newsletter Signup",prompt:"Create a newsletter subscription form with email input and subscribe button. Include email validation, loading states, success confirmation message, and error handling. Add a clean, modern design with an optional name field and privacy notice."},{icon:eO.Image,label:"Image Carousel",prompt:"Build a smooth image carousel with auto-play functionality, navigation arrows, and dot indicators. Include touch/swipe support for mobile, keyboard navigation, pause on hover, and smooth transitions between slides. Make it responsive."},{icon:rO.Kv,label:"Memory Game",prompt:"Create a memory matching card game where players flip cards to find pairs. Include a timer, move counter, shuffle functionality, win detection, and restart button. Add smooth flip animations and celebratory effects when all pairs are found."},{icon:rV.ChartActivity,label:"BMI Calculator",prompt:"Design a BMI calculator with inputs for height and weight in both metric and imperial units. Display the calculated BMI with color-coded health category, visual indicator, and health recommendations. Include a clear, informative interface."}],[{icon:rB.Calendar,label:"Event Calendar",prompt:"Create an event calendar with month view, day selection, and event creation. Include the ability to add, edit, and delete events with titles, times, and descriptions. Add color coding for different event types and navigation between months."},{icon:rF,label:"Shopping Cart",prompt:"Build a shopping cart interface with product listings, add to cart functionality, quantity controls, and price calculations. Include item removal, subtotal and total display, and a checkout button. Make it responsive with smooth animations."},{icon:rU.MusicalNotes,label:"Music Player",prompt:"Design an audio player with play/pause controls, progress bar, volume control, and playlist. Include track information display, next/previous buttons, shuffle and repeat options. Add a modern interface with smooth animations and waveform visualization."},{icon:eQ.User,label:"User Profile",prompt:"Create a user profile page with avatar, name, bio, and contact information. Include sections for recent activity, stats, and achievements. Add edit mode with form inputs for updating profile information. Make it responsive with a clean, modern design."}]];function rq(e){let r,i,a,o,l=(0,n.c)(11),{onSuggestionClick:c}=e,[u,d]=(0,s.useState)(0);l[0]===Symbol.for("react.memo_cache_sentinel")?(r=()=>{d(rW)},l[0]=r):r=l[0];let m=r,h=r$[u];if(!h)return null;if(l[1]!==u||l[2]!==h||l[3]!==c){let e;l[5]!==u||l[6]!==c?(e=(e,n)=>(0,t.jsxs)(L.Button,{variant:"secondary",size:"sm",rounded:!0,onClick:()=>c(e.prompt),className:"!px-3 text-v0-gray-900 [&>svg]:text-v0-gray-900 hover:text-v0-gray-1000 hover:[&>svg]:text-v0-gray-1000",children:[(0,t.jsx)(e.icon,{}),e.label]},`${u}-${n}`),l[5]=u,l[6]=c,l[7]=e):e=l[7],i=h.map(e),l[1]=u,l[2]=h,l[3]=c,l[4]=i}else i=l[4];return l[8]===Symbol.for("react.memo_cache_sentinel")?